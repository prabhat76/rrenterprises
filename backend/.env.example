PORT=4000
NODE_ENV=production

# Database Configuration
# - Leave DB_HOST empty to use local SQLite (recommended for development)
# - Set these to your Neon/Postgres values when using a remote DB
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432
DB_DIALECT=postgres
DB_SSL=true

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL for CORS (Your Vercel frontend URL)
FRONTEND_URL=https://your-frontend.vercel.app